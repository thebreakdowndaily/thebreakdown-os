    "check:bundle": "node -e \"console.log('Placeholder: bundle analyzer')\"",
    "check:lighthouse": "node -e \"console.log('Placeholder: lighthouse audit')\"",
    "check:audit": "node -e \"console.log('Placeholder: audit script')\"",
    "check:performance": "node -e \"console.log('Placeholder: performance script')\"",
    "check:security": "node -e \"console.log('Placeholder: security script')\"",
    "check:verify": "npm run checkpoint:b",
    "prepare:artifacts": "node scripts/prepare-artifacts.js",
    "ci:verify": "run-s prepare:artifacts check:lint check:type check:test check:build check:a11y check:storybook check:bundle check:lighthouse check:audit check:performance check:security",
    "test:all": "npm run test && npm run test:dataset && npm run test:dataset:e2e && npm run test:compiler && npm run test:graph && npm run test:engine && npm run test:kxe && npm run test:renderer && npm run test:plugin-sdk && npm run test:timeline && npm run test:citations && npm run test:relationship-graph"
