",\"li\",\"/Home\",{\"className\":\"flex items-center gap-1\",\"children\":[false,[\"$\",\"a\",null,{\"href\":\"/\",\"className\":\"text-amber-400 hover:text-amber-300 transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/timelineTimeline\",{\"className\":\"flex items-center gap-1\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-gray-600 mx-1\",\"aria-hidden\":\"true\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-gray-100 font-medium\",\"aria-current\":\"page\",\"children\":\"Timeline\"}]]}]]}]}],[\"$\",\"main\",null,{\"className\":\"flex-1 w-full\",\"role\":\"main\",\"children\":[\"$\",\"div\",null,{\"className\":\"w-full max-w-[1440px] mx-auto px-4 sm:px-8 py-8\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-3xl sm:text-4xl font-bold text-[#F5F5F5] mb-2\",\"children\":\"Timeline\"}],[\"$\",\"p\",null,{\"className\":\"text-lg text-[#A1A1AA] mb-8\",\"children\":\"All major events across stories, policies, and entities.\"}],[\"$\",\"$L19\",null,{\"events\":[{\"date\":\"2026-07-08\",\"title\":\"WHO Global Status Report on Cancer 2026 Published\",\"description\":\"WHO releases the most comprehensive global cancer assessment to date, spanning 20.6M diagnoses, 10M deaths, 7 recommendations across 3 strategic pillars.\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"2026-07-05\",\"title\":\"Survey Flags Backlash\",\"description\":\"LocalCircles survey: 53% call rollout disastrous, 66% report mileage drop.\",\"source\":\"E20 Backlash: India's Ethanol Push and the Consumer Revolt That Followed\",\"sourceSlug\":\"/story/ethanol-backlash\",\"category\":\"story\"},{\"date\":\"2026-07-05\",\"title\":\"ZEE5 Removes Satluj\",\"description\":\"I&B Ministry notice citing security concerns; film removed within 48 hours.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2026-07-03\",\"title\":\"Satluj Released Uncut on ZEE5\",\"description\":\"Released quietly without CBFC certification under new title Satluj.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2026-07-02\",\"title\":\"Mission 360 Revealed\",\"description\":\"BJP leadership intensifies Mission 360 strategy. NDA strength reaches 319 after 20 TMC MPs defect to NCPI, 6 Shiv Sena (UBT) MPs switch.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-06-24\",\"title\":\"Congress Alleges Conspiracy\",\"description\":\"Jairam Ramesh accuses BJP of chasing two-thirds majority to amend the Constitution and end reservations.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-06-20\",\"title\":\"2026 Final Round Talks\",\"description\":\"Final round of negotiations underway in Vienna with focus on sanctions sequencing and verification mechanisms.\",\"source\":\"US-Iran Relations: From Maximum Pressure to Nuclear Negotiations\",\"sourceSlug\":\"/story/us-iran-relations\",\"category\":\"story\"},{\"date\":\"2026-06-19\",\"title\":\"Investigation Published\",\"description\":\"Indian Express investigation of all 104 EWS-selected candidates reveals profile mismatches.\",\"source\":\"Who Really Gets the EWS Quota? An Investigation into UPSC's 104 Selections\",\"sourceSlug\":\"/story/ews-quota-upsc-investigation\",\"category\":\"story\"},{\"date\":\"2026-06-15\",\"title\":\"Revised NDCs Submitted\",\"description\":\"India submits enhanced NDCs to UNFCCC with updated emission intensity reduction target of 45% by 2030.\",\"source\":\"India's ₹11 Lakh Crore Climate Finance Challenge\",\"sourceSlug\":\"/story/climate-finance\",\"category\":\"story\"},{\"date\":\"2026-06-15\",\"title\":\"6 Crore Hospitalization Milestone\",\"description\":\"AB-PMJAY crosses 6.2 crore cumulative hospitalizations, average claim cost rising to ₹8,600 per hospitalization.\",\"source\":\"Ayushman Bharat: India's ₹30,000 Crore Bet on Universal Health Coverage\",\"sourceSlug\":\"/story/ayushman-bharat\",\"category\":\"story\"},{\"date\":\"2026-06-15\",\"title\":\"Revised NDCs Submitted\",\"description\":\"India submits enhanced NDCs to UNFCCC with updated emission intensity reduction target of 45% by 2030.\",\"source\":\"India's Climate Action Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-06-01\",\"title\":\"troops at 60,000 each side\",\"description\":\"Military deployment on both sides reaches 60,000 troops, with China operating new forward air bases in Hotan and Shigatse.\",\"source\":\"India-China at the Crossroads: Four Years After Galwan, the Border Remains the Flashpoint\",\"sourceSlug\":\"/story/india-china-border-tensions\",\"category\":\"story\"},{\"date\":\"2026-06-01\",\"title\":\"Centre Plans Revival of Bills\",\"description\":\"Home Ministry drafts revised delimitation legislation aimed at passing in the Monsoon Session, buoyed by Bengal victory.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-06-01\",\"title\":\"400 Million Subscribers Crossed\",\"description\":\"India's 5G subscriber base crosses 40 crore. But enterprise 5G contributes less than 5% of operator revenue, and the \\\"killer app\\\" remains elusive.\",\"source\":\"India's 5G Revolution: 400 Million Subscribers and Still Waiting for the Killer App\",\"sourceSlug\":\"/story/india-5g-rollout\",\"category\":\"story\"},{\"date\":\"2026-06-01\",\"title\":\"Charging Infrastructure Push Announced\",\"description\":\"MoHI announces revised target of 1 lakh public charging stations by 2029, mandates charging points at all petrol pumps and new residential complexes.\",\"source\":\"India's EV Paradox: Rising Sales, Stalled Charging, and the ₹4 Lakh Crore Battery Import Bill\",\"sourceSlug\":\"/story/india-ev-paradox\",\"category\":\"story\"},{\"date\":\"2026-05-09\",\"title\":\"Suvendu Adhikari Sworn In\",\"description\":\"Adhikari takes oath as West Bengal's first BJP chief minister in a ceremony featuring Bengali cultural motifs.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-05-04\",\"title\":\"BJP Wins Bengal With 206 Seats\",\"description\":\"BJP wins 206/294 seats in West Bengal, ending TMC's 15-year rule. Suvendu Adhikari defeats Mamata Banerjee in Bhabanipur by 15,105 votes.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-04-28\",\"title\":\"BJP's 4-Pronged Bengal Strategy\",\"description\":\"BJP deploys strategy focused on demographic change, corruption, Hindu identity, and women's safety for Bengal polls.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-04-18\",\"title\":\"DMK's Stalin Claims Victory\",\"description\":\"Tamil Nadu CM MK Stalin declares the defeat \\\"a fire that scorched Delhi's arrogance.\\\" Southern states opposed delimitation fearing seat loss.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-04-17\",\"title\":\"Bill Defeated in Lok Sabha\",\"description\":\"In a major setback, the Bill gets 298 votes for and 230 against — 54 short of the 352 required for a two-thirds majority. Opposition unites.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-04-16\",\"title\":\"Delimitation Bills Introduced\",\"description\":\"Government introduces Constitution (131st Amendment) Bill, Delimitation Bill, and UT Laws Bill in Lok Sabha — proposing to increase Lok Sabha to 850 seats.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-04-15\",\"title\":\"FDI Crosses $85 Billion\",\"description\":\"Cumulative FDI from supply chain relocation investments crosses $85 billion since 2023.\",\"source\":\"The Great Supply Chain Shift: Can India Capture the China+1 Opportunity?\",\"sourceSlug\":\"/story/supply-chain-shift\",\"category\":\"story\"},{\"date\":\"2026-04-15\",\"title\":\"FDI Crosses $85 Billion\",\"description\":\"Cumulative FDI from supply chain relocation investments crosses $85 billion since 2023.\",\"source\":\"India's Supply Chain Transformation\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-04-08\",\"title\":\"Status Quo Maintained\",\"description\":\"MPC keeps repo rate at 6.25% with accommodative stance amid global uncertainty.\",\"source\":\"RBI Repo Rate: Decoding Monetary Policy in a Changing Economy\",\"sourceSlug\":\"/story/rbi-repo-rate\",\"category\":\"story\"},{\"date\":\"2026-04-08\",\"title\":\"Status Quo Maintained\",\"description\":\"MPC keeps repo rate at 6.25% with accommodative stance amid global uncertainty.\",\"source\":\"RBI Monetary Policy Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-04-01\",\"title\":\"Investigation Published\",\"description\":\"The Breakdown publishes investigation across 6 states.\",\"source\":\"PM Fasal Bima Yojana: The Claims That Never Reached Farmers\",\"sourceSlug\":\"/story/pm-fasal-bima-claims\",\"category\":\"story\"},{\"date\":\"2026-04-01\",\"title\":\"Investigation Published\",\"description\":\"The Breakdown publishes investigation across 6 states.\",\"source\":\"PMFBY — Crop Insurance in India\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-03-20\",\"title\":\"2026 Amendments Pass Lok Sabha\",\"description\":\"Amendments to DPDP Act passed in Lok Sabha, expanding data fiduciary obligations and cross-border data flow rules.\",\"source\":\"Digital Personal Data Protection: India's Privacy Law Comes of Age\",\"sourceSlug\":\"/story/dpdp-bill\",\"category\":\"story\"},{\"date\":\"2026-03-20\",\"title\":\"2026 Amendments Pass Lok Sabha\",\"description\":\"Amendments to DPDP Act passed in Lok Sabha, expanding data fiduciary obligations and cross-border data flow rules.\",\"source\":\"India's Data Protection Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-03-15\",\"title\":\"CCEA Approves 5 Fab Proposals\",\"description\":\"Cabinet Committee on Economic Affairs approves 5 new fabrication plant proposals.\",\"source\":\"India's ₹1.2 Lakh Crore Semiconductor Push: Can the Dream Take Silicon?\",\"sourceSlug\":\"/story/semiconductor-pli\",\"category\":\"story\"},{\"date\":\"2026-03-15\",\"title\":\"CCEA Approves 5 Fab Proposals\",\"description\":\"Cabinet Committee on Economic Affairs approves 5 new fabrication plant proposals.\",\"source\":\"India's Semiconductor Push\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-03-12\",\"title\":\"BJP Finalises Bengal Strategy\",\"description\":\"PM Modi and Amit Shah chair key meeting to finalise candidates and strategy for Bengal and Kerala assembly polls.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2026-03-06\",\"title\":\"CSE 2025 Results Declared\",\"description\":\"958 candidates recommended; 104 under EWS quota for 1,087 vacancies.\",\"source\":\"Who Really Gets the EWS Quota? An Investigation into UPSC's 104 Selections\",\"sourceSlug\":\"/story/ews-quota-upsc-investigation\",\"category\":\"story\"},{\"date\":\"2026-03-01\",\"title\":\"Rural UPI at ₹12L Cr\",\"description\":\"Rural UPI transactions reach ₹12 lakh crore annually.\",\"source\":\"Digital Payments in Rural India: UPI's Unseen Revolution\",\"sourceSlug\":\"/story/digital-payments-boom\",\"category\":\"story\"},{\"date\":\"2026-03-01\",\"title\":\"Parliamentary Committee on Education\",\"description\":\"Standing Committee on Education submits report calling for urgent remedial measures including teacher recruitment drive and learning outcome targets.\",\"source\":\"India's Education Paradox: Rising Enrolment, Falling Learning — What Went Wrong?\",\"sourceSlug\":\"/story/indian-education-crisis\",\"category\":\"story\"},{\"date\":\"2026-03-01\",\"title\":\"FTA Round 14\",\"description\":\"14th round of FTA negotiations concludes with progress on rules of origin and services, but tariffs and migration remain unresolved.\",\"source\":\"India-UK Relations: Beyond Colonial History to a Modern Strategic Partnership\",\"sourceSlug\":\"/story/india-uk-relations\",\"category\":\"story\"},{\"date\":\"2026-03-01\",\"title\":\"Rural UPI at ₹12L Cr\",\"description\":\"Rural UPI transactions reach ₹12 lakh crore annually.\",\"source\":\"UPI — The Digital Payments Revolution\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-02-15\",\"title\":\"Parliamentary Debate on Inequality\",\"description\":\"Opposition parties force debate on rising inequality, citing Oxfam and World Inequality Lab data. Government defends growth-first approach.\",\"source\":\"Income Inequality in India: The Top 1% Now Owns 40% of the Wealth\",\"sourceSlug\":\"/story/income-inequality-india\",\"category\":\"story\"},{\"date\":\"2026-02-02\",\"title\":\"20th Anniversary\",\"description\":\"Cumulative expenditure over ₹8 lakh crore.\",\"source\":\"MGNREGA Completes 20 Years: A Data-Driven Assessment of Rural Employment\",\"sourceSlug\":\"/story/mgnrega-reform\",\"category\":\"story\"},{\"date\":\"2026-02-02\",\"title\":\"20th Anniversary\",\"description\":\"Cumulative expenditure over ₹8 lakh crore.\",\"source\":\"MGNREGA — Two Decades of Rural Employment\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2026-01-26\",\"title\":\"Republic Day with Quad Leaders\",\"description\":\"Quad leaders attend India's Republic Day as chief guests, signalling Indo-Pacific strategic alignment.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"2025-12-05\",\"title\":\"Amit Shah's Operation Bengal\",\"description\":\"Shah announces \\\"Mission 2026\\\" for West Bengal, plans to spend maximum days in Bengal from a house in Salt Lake.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2025-12-01\",\"title\":\"India-US Defence Pact\",\"description\":\"India and US sign landmark defence industrial cooperation roadmap covering jet engines, drones, and maritime domain awareness.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"2025-12-01\",\"title\":\"Bilateral Trade Record\",\"description\":\"India-Russia trade reaches $65 billion, driven primarily by Indian crude oil purchases.\",\"source\":\"India-Russia: The Enduring Partnership Tested by War and Realignment\",\"sourceSlug\":\"/story/india-russia-relations\",\"category\":\"story\"},{\"date\":\"2025-11-23\",\"title\":\"BJP Sweeps Bihar\",\"description\":\"NDA wins Bihar assembly elections in a landslide, giving Amit Shah the \\\"Bihar model\\\" template for Bengal.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2025-11-15\",\"title\":\"Breakthrough Framework\",\"description\":\"US and Iran agree on framework for enhanced JCPOA with stricter IAEA inspections and extended sunset clauses.\",\"source\":\"US-Iran Relations: From Maximum Pressure to Nuclear Negotiations\",\"sourceSlug\":\"/story/us-iran-relations\",\"category\":\"story\"},{\"date\":\"2025-10-25\",\"title\":\"Wen Jiabao-like Thaw Attempts\",\"description\":\"India-China Special Representatives meet in Beijing for first border talks since 2019, but no breakthrough achieved.\",\"source\":\"India-China at the Crossroads: Four Years After Galwan, the Border Remains the Flashpoint\",\"sourceSlug\":\"/story/india-china-border-tensions\",\"category\":\"story\"},{\"date\":\"2025-10-01\",\"title\":\"Disengagement Progress\",\"description\":\"India and China complete disengagement at Depsang and Demchok after 4 years of negotiations, but large PLA troop presence persists.\",\"source\":\"India-China: Two Asian Giants in an Era of Mistrust and Strategic Rivalry\",\"sourceSlug\":\"/story/india-china-relations\",\"category\":\"story\"},{\"date\":\"2025-09-15\",\"title\":\"ICDS Digitisation Push\",\"description\":\"All anganwadi centres equipped with smartphones for real-time nutrition tracking under ICDS-CAS.\",\"source\":\"Anganwadi Centres: India's Frontline Nutrition Workers Are Burning Out\",\"sourceSlug\":\"/story/anganwadi-icds\",\"category\":\"story\"},{\"date\":\"2025-09-15\",\"title\":\"Trade Crosses $200 Billion\",\"description\":\"India-US bilateral trade surpasses $200 billion for the first time, with the US becoming India's top trading partner.\",\"source\":\"India-US Relations: From Nuclear Deal to Critical Technology Partnership\",\"sourceSlug\":\"/story/india-us-relations\",\"category\":\"story\"},{\"date\":\"2025-09-15\",\"title\":\"ICDS Digitisation Push\",\"description\":\"All anganwadi centres equipped with smartphones for real-time nutrition tracking under ICDS-CAS.\",\"source\":\"ICDS — India's Nutrition Programme Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2025-09-01\",\"title\":\"Revised PLI Scheme Announced\",\"description\":\"Government expands PLI outlay to ₹1.2 lakh crore, covering design, fabrication, packaging, and testing.\",\"source\":\"India's ₹1.2 Lakh Crore Semiconductor Push: Can the Dream Take Silicon?\",\"sourceSlug\":\"/story/semiconductor-pli\",\"category\":\"story\"},{\"date\":\"2025-09-01\",\"title\":\"Revised PLI Scheme Announced\",\"description\":\"Government expands PLI outlay to ₹1.2 lakh crore, covering design, fabrication, packaging, and testing.\",\"source\":\"India's Semiconductor Push\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2025-08-12\",\"title\":\"SC Dismisses PIL\",\"description\":\"Supreme Court dismisses PIL challenging E20 rollout.\",\"source\":\"E20 Backlash: India's Ethanol Push and the Consumer Revolt That Followed\",\"sourceSlug\":\"/story/ethanol-backlash\",\"category\":\"story\"},{\"date\":\"2025-06-05\",\"title\":\"First Rate Cut\",\"description\":\"MPC cuts repo rate by 25 bps to 6.25% as growth concerns outweigh inflation.\",\"source\":\"RBI Repo Rate: Decoding Monetary Policy in a Changing Economy\",\"sourceSlug\":\"/story/rbi-repo-rate\",\"category\":\"story\"},{\"date\":\"2025-06-05\",\"title\":\"First Rate Cut\",\"description\":\"MPC cuts repo rate by 25 bps to 6.25% as growth concerns outweigh inflation.\",\"source\":\"RBI Monetary Policy Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2025-06-01\",\"title\":\"300 Million Subscribers Landmark\",\"description\":\"India reaches 30 crore 5G subscribers, becoming the second-largest 5G market globally after China, which crossed 90 crore in the same period.\",\"source\":\"India's 5G Revolution: 400 Million Subscribers and Still Waiting for the Killer App\",\"sourceSlug\":\"/story/india-5g-rollout\",\"category\":\"story\"},{\"date\":\"2025-04-01\",\"title\":\"Nationwide E20 Rollout\",\"description\":\"India achieves 20% ethanol blending nationwide, 5 years ahead of target.\",\"source\":\"E20 Backlash: India's Ethanol Push and the Consumer Revolt That Followed\",\"sourceSlug\":\"/story/ethanol-backlash\",\"category\":\"story\"},{\"date\":\"2025-02-01\",\"title\":\"Budget 2025-26 Allocation\",\"description\":\"Education allocation reaches ₹1.48 lakh crore, with focus on digital infrastructure and teacher training.\",\"source\":\"Education Budget: Widening Gap Between Spending and Learning Outcomes\",\"sourceSlug\":\"/story/education-budget\",\"category\":\"story\"},{\"date\":\"2025-02-01\",\"title\":\"Budget 2025-26 Allocation\",\"description\":\"Education allocation reaches ₹1.48 lakh crore, with focus on digital infrastructure and teacher training.\",\"source\":\"Education Policy & Budget Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2025-01-25\",\"title\":\"Comprehensive Strategic Partnership\",\"description\":\"Ties upgraded to Comprehensive Strategic Partnership; India offers $1 billion defence credit line.\",\"source\":\"India-Indonesia: How Maritime Neighbours Are Reshaping the Indo-Pacific\",\"sourceSlug\":\"/story/india-indonesia-relations\",\"category\":\"story\"},{\"date\":\"2025-01-15\",\"title\":\"ASER 2025 Report\",\"description\":\"Annual Status of Education Report shows learning outcomes declining for third consecutive year despite increased budget allocation.\",\"source\":\"India's Education Paradox: Rising Enrolment, Falling Learning — What Went Wrong?\",\"sourceSlug\":\"/story/indian-education-crisis\",\"category\":\"story\"},{\"date\":\"2024-12-01\",\"title\":\"Global Status Report on Cancer Initiated\",\"description\":\"WHO begins compiling comprehensive status report covering national capacities, treatment access, and financing gaps across all 194 member states.\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"2024-09-20\",\"title\":\"India-Middle East-Europe Corridor\",\"description\":\"IMEC logistics corridor announced at G20, positioning India as a transshipment hub between Asia and Europe.\",\"source\":\"The Great Supply Chain Shift: Can India Capture the China+1 Opportunity?\",\"sourceSlug\":\"/story/supply-chain-shift\",\"category\":\"story\"},{\"date\":\"2024-09-20\",\"title\":\"India-Middle East-Europe Corridor\",\"description\":\"IMEC logistics corridor announced at G20, positioning India as a transshipment hub between Asia and Europe.\",\"source\":\"India's Supply Chain Transformation\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2024-09-01\",\"title\":\"Revision Committee Demands 127 Cuts\",\"description\":\"Total cuts escalated to 127, including removing Khalra's name.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2024-08-15\",\"title\":\"CAG Report Flags Delays\",\"description\":\"CAG report highlights systemic delays in claim settlement.\",\"source\":\"PM Fasal Bima Yojana: The Claims That Never Reached Farmers\",\"sourceSlug\":\"/story/pm-fasal-bima-claims\",\"category\":\"story\"},{\"date\":\"2024-08-15\",\"title\":\"CAG Report Flags Delays\",\"description\":\"CAG report highlights systemic delays in claim settlement.\",\"source\":\"PMFBY — Crop Insurance in India\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2024-06-10\",\"title\":\"Vedanta-Foxconn JV Collapses\",\"description\":\"Joint venture between Vedanta and Foxconn to set up a $19.5 billion semiconductor fab dissolves.\",\"source\":\"India's ₹1.2 Lakh Crore Semiconductor Push: Can the Dream Take Silicon?\",\"sourceSlug\":\"/story/semiconductor-pli\",\"category\":\"story\"},{\"date\":\"2024-06-10\",\"title\":\"Vedanta-Foxconn JV Collapses\",\"description\":\"Joint venture between Vedanta and Foxconn to set up a $19.5 billion semiconductor fab dissolves.\",\"source\":\"India's Semiconductor Push\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2024-06-04\",\"title\":\"Modi 3.0 Takes Office\",\"description\":\"BJP returns with 240 seats, NDA at 293 — first time Modi government without single-party majority. Two-thirds majority out of reach.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2024-06-01\",\"title\":\"Parliamentary Committee Summons\",\"description\":\"Parliamentary committee on IT summons MeitY, UIDAI, and ICMR officials for deposition on the breach.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2024-06-01\",\"title\":\"Airtel-Jio Coverage Race Peaks\",\"description\":\"Jio and Airtel expand 5G to over 5,000 cities each, covering 85% of urban India. Jio claims True 5G (SA-ready), Airtel relies on NSA mode.\",\"source\":\"India's 5G Revolution: 400 Million Subscribers and Still Waiting for the Killer App\",\"sourceSlug\":\"/story/india-5g-rollout\",\"category\":\"story\"},{\"date\":\"2024-06-01\",\"title\":\"Parliamentary Committee Summons\",\"description\":\"Parliamentary committee on IT summons MeitY, UIDAI, and ICMR officials for deposition on the breach.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2024-04-01\",\"title\":\"ED Launches Investigations\",\"description\":\"Enforcement Directorate begins investigating multiple electoral bond donors under FEMA and money laundering provisions.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2024-03-15\",\"title\":\"FAME-III Scheme Announced\",\"description\":\"Government announces FAME-III with ₹10,000 crore outlay, extending demand incentives for another three years and doubling the charging station target to 46,000.\",\"source\":\"India's EV Paradox: Rising Sales, Stalled Charging, and the ₹4 Lakh Crore Battery Import Bill\",\"sourceSlug\":\"/story/india-ev-paradox\",\"category\":\"story\"},{\"date\":\"2024-03-14\",\"title\":\"EC Publishes Donor Data\",\"description\":\"Election Commission publishes donor data on its website — revealing for the first time who gave how much to which party.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2024-03-11\",\"title\":\"SBI Ordered to Disclose Data\",\"description\":\"Supreme Court extends deadline and orders SBI to submit all electoral bond details to EC by March 12, 2024.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2024-02-15\",\"title\":\"Supreme Court Strikes Down Scheme\",\"description\":\"5-judge Constitution Bench unanimously declares Electoral Bond Scheme unconstitutional as a violation of Article 19(1)(a) — right to information.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2024-02-01\",\"title\":\"IARC Projections Warn of 77% Increase by 2050\",\"description\":\"IARC releases projections showing new cancer cases rising from 20 million to 35 million by 2050, with the highest proportional increase in low-HDI countries (142%).\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"2024-01-15\",\"title\":\"AEPS Fraud Reports Surface\",\"description\":\"Multiple reports emerge of Aadhaar-enabled Payment System (AEPS) fraud linked to the leaked data.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2024-01-15\",\"title\":\"Revised Empanelment Guidelines\",\"description\":\"NHA issues updated criteria mandating minimum bed strength, specialist availability, and quality accreditation for private hospitals.\",\"source\":\"Ayushman Bharat: India's ₹30,000 Crore Bet on Universal Health Coverage\",\"sourceSlug\":\"/story/ayushman-bharat\",\"category\":\"story\"},{\"date\":\"2024-01-15\",\"title\":\"AEPS Fraud Reports Surface\",\"description\":\"Multiple reports emerge of Aadhaar-enabled Payment System (AEPS) fraud linked to the leaked data.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-12-01\",\"title\":\"World Inequality Lab Report\",\"description\":\"World Inequality Lab report shows India's top 10% captured 57% of national income in 2023, among the highest share globally.\",\"source\":\"Income Inequality in India: The Top 1% Now Owns 40% of the Wealth\",\"sourceSlug\":\"/story/income-inequality-india\",\"category\":\"story\"},{\"date\":\"2023-12-01\",\"title\":\"125 Million Users Milestone\",\"description\":\"India crosses 12.5 crore 5G subscribers within 14 months of launch — the fastest adoption of any generation of mobile technology in the country.\",\"source\":\"India's 5G Revolution: 400 Million Subscribers and Still Waiting for the Killer App\",\"sourceSlug\":\"/story/india-5g-rollout\",\"category\":\"story\"},{\"date\":\"2023-11-01\",\"title\":\"DPDP Act Test\",\"description\":\"The breach becomes the first major test of the Digital Personal Data Protection Act 2023, passed just two months prior.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2023-11-01\",\"title\":\"Supreme Court Hearings Begin\",\"description\":\"Supreme Court begins final hearings on petitions challenging the constitutional validity of electoral bonds.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2023-11-01\",\"title\":\"DPDP Act Test\",\"description\":\"The breach becomes the first major test of the Digital Personal Data Protection Act 2023, passed just two months prior.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-10-20\",\"title\":\"CBI Investigation Launched\",\"description\":\"CBI registers a case and begins investigating the breach, focusing on data provenance and responsible parties.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2023-10-20\",\"title\":\"CBI Investigation Launched\",\"description\":\"CBI registers a case and begins investigating the breach, focusing on data provenance and responsible parties.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-10-15\",\"title\":\"Indian Authorities Notified\",\"description\":\"Resecurity alerts CERT-In and Indian law enforcement agencies about the massive data breach.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2023-10-15\",\"title\":\"Indian Authorities Notified\",\"description\":\"Resecurity alerts CERT-In and Indian law enforcement agencies about the massive data breach.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-10-12\",\"title\":\"Sample Records Verified\",\"description\":\"Resecurity verifies sample records through the government's \\\"Verify Aadhaar\\\" portal, confirming authenticity.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2023-10-12\",\"title\":\"Sample Records Verified\",\"description\":\"Resecurity verifies sample records through the government's \\\"Verify Aadhaar\\\" portal, confirming authenticity.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-10-10\",\"title\":\"Resecurity HUNTER Discovers Breach\",\"description\":\"Resecurity's HUNTER threat intelligence unit detects the listing and begins analysis of sample records.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2023-10-10\",\"title\":\"Resecurity HUNTER Discovers Breach\",\"description\":\"Resecurity's HUNTER threat intelligence unit detects the listing and begins analysis of sample records.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-10-09\",\"title\":\"Data Posted on Breach Forums\",\"description\":\"Threat actor \\\"pwn0001\\\" posts 815 million Indian citizen records for sale at $80,000 on Breach Forums.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2023-10-09\",\"title\":\"Data Posted on Breach Forums\",\"description\":\"Threat actor \\\"pwn0001\\\" posts 815 million Indian citizen records for sale at $80,000 on Breach Forums.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-09-19\",\"title\":\"Nari Shakti Vandan Adhiniyam Passed\",\"description\":\"Parliament passes 106th Constitutional Amendment reserving 33% of Lok Sabha and Assembly seats for women, tied to future delimitation.\",\"source\":\"Mission 360: Inside BJP's Push for a Two-Thirds Majority and the Battle Over India's Constitutional Future\",\"sourceSlug\":\"/story/bjp-mission-360\",\"category\":\"story\"},{\"date\":\"2023-09-09\",\"title\":\"G20 Presidency Climate Push\",\"description\":\"Under its G20 presidency, India pushes for reform of multilateral climate finance architecture.\",\"source\":\"India's ₹11 Lakh Crore Climate Finance Challenge\",\"sourceSlug\":\"/story/climate-finance\",\"category\":\"story\"},{\"date\":\"2023-09-09\",\"title\":\"G20 Presidency Success\",\"description\":\"India's G20 presidency yields New Delhi Leaders' Declaration, inclusion of African Union in G20, and Voice of Global South Summit institutionalisation.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"2023-09-09\",\"title\":\"IMEC Announced\",\"description\":\"India-Middle East-Europe Corridor announced at G20 as an alternative connectivity project linking India to Europe via the Middle East.\",\"source\":\"India and Europe: A Strategic Partnership Searching for Substance\",\"sourceSlug\":\"/story/india-europe-relations\",\"category\":\"story\"},{\"date\":\"2023-09-09\",\"title\":\"G20 Presidency Climate Push\",\"description\":\"Under its G20 presidency, India pushes for reform of multilateral climate finance architecture.\",\"source\":\"India's Climate Action Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-09-01\",\"title\":\"EV Sales Surge Past 1.5 Million\",\"description\":\"Annual EV sales cross 1.5 million units for the first time, driven by 2-wheeler adoption and e-rickshaws. EVs reach 5.2% of total auto sales.\",\"source\":\"India's EV Paradox: Rising Sales, Stalled Charging, and the ₹4 Lakh Crore Battery Import Bill\",\"sourceSlug\":\"/story/india-ev-paradox\",\"category\":\"story\"},{\"date\":\"2023-08-11\",\"title\":\"DPDP Act Receives Assent\",\"description\":\"Digital Personal Data Protection Act 2023 receives presidential assent, replacing the 2019 bill.\",\"source\":\"Digital Personal Data Protection: India's Privacy Law Comes of Age\",\"sourceSlug\":\"/story/dpdp-bill\",\"category\":\"story\"},{\"date\":\"2023-08-11\",\"title\":\"DPDP Act Receives Assent\",\"description\":\"Digital Personal Data Protection Act 2023 receives presidential assent, replacing the 2019 bill.\",\"source\":\"India's Data Protection Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-08-01\",\"title\":\"Pulled from TIFF 2023\",\"description\":\"Withdrawn from Toronto International Film Festival after government intervention.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2023-07-04\",\"title\":\"CBFC Demands 21 Cuts\",\"description\":\"A certificate granted but 21 edits demanded.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2023-06-15\",\"title\":\"NEP Mid-Term Review\",\"description\":\"Government conducts mid-term review of NEP implementation, identifies gaps in 14 states.\",\"source\":\"Education Budget: Widening Gap Between Spending and Learning Outcomes\",\"sourceSlug\":\"/story/education-budget\",\"category\":\"story\"},{\"date\":\"2023-06-15\",\"title\":\"NEP Mid-Term Review\",\"description\":\"Government conducts mid-term review of NEP implementation, identifies gaps in 14 states.\",\"source\":\"Education Policy & Budget Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-06-01\",\"title\":\"Rural UPI Crosses ₹5L Cr\",\"description\":\"Annual rural UPI transactions cross ₹5 lakh crore.\",\"source\":\"Digital Payments in Rural India: UPI's Unseen Revolution\",\"sourceSlug\":\"/story/digital-payments-boom\",\"category\":\"story\"},{\"date\":\"2023-06-01\",\"title\":\"Apple Supply Chain Shift\",\"description\":\"Apple ramps up iPhone production in India to 14% of global output, with Foxconn, Wistron, and Pegatron expanding facilities.\",\"source\":\"The Great Supply Chain Shift: Can India Capture the China+1 Opportunity?\",\"sourceSlug\":\"/story/supply-chain-shift\",\"category\":\"story\"},{\"date\":\"2023-06-01\",\"title\":\"Rural UPI Crosses ₹5L Cr\",\"description\":\"Annual rural UPI transactions cross ₹5 lakh crore.\",\"source\":\"UPI — The Digital Payments Revolution\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-06-01\",\"title\":\"Apple Supply Chain Shift\",\"description\":\"Apple ramps up iPhone production in India to 14% of global output, with Foxconn, Wistron, and Pegatron expanding facilities.\",\"source\":\"India's Supply Chain Transformation\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-04-06\",\"title\":\"Rate Pause Begins\",\"description\":\"MPC pauses after delivering cumulative 250 bps hike; repo rate held at 6.50%.\",\"source\":\"RBI Repo Rate: Decoding Monetary Policy in a Changing Economy\",\"sourceSlug\":\"/story/rbi-repo-rate\",\"category\":\"story\"},{\"date\":\"2023-04-06\",\"title\":\"Rate Pause Begins\",\"description\":\"MPC pauses after delivering cumulative 250 bps hike; repo rate held at 6.50%.\",\"source\":\"RBI Monetary Policy Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-02-01\",\"title\":\"Universal ONORC Coverage\",\"description\":\"ONORC achieves 100% coverage across all states and union territories, serving 81 crore beneficiaries.\",\"source\":\"Digitizing PDS: How Technology Plugged the Leakage in India's Food Security Net\",\"sourceSlug\":\"/story/ration-digitization\",\"category\":\"story\"},{\"date\":\"2023-02-01\",\"title\":\"Universal ONORC Coverage\",\"description\":\"ONORC achieves 100% coverage across all states and union territories, serving 81 crore beneficiaries.\",\"source\":\"PDS Digitization Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2023-01-31\",\"title\":\"iCET Launch\",\"description\":\"Initiative on Critical and Emerging Technologies launched to co-develop AI, semiconductors, space, and 5G/6G.\",\"source\":\"India-US Relations: From Nuclear Deal to Critical Technology Partnership\",\"sourceSlug\":\"/story/india-us-relations\",\"category\":\"story\"},{\"date\":\"2022-11-07\",\"title\":\"SC Upholds EWS Quota\",\"description\":\"Supreme Court by 3:2 majority upholds constitutional validity of EWS quota.\",\"source\":\"Who Really Gets the EWS Quota? An Investigation into UPSC's 104 Selections\",\"sourceSlug\":\"/story/ews-quota-upsc-investigation\",\"category\":\"story\"},{\"date\":\"2022-11-01\",\"title\":\"Film Submitted to CBFC\",\"description\":\"RSVP Movies submits Punjab '95 for certification.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2022-10-01\",\"title\":\"5G Services Launched in 13 Cities\",\"description\":\"PM Modi launches 5G services at India Mobile Congress 2022, starting with Delhi, Mumbai, Chennai, Kolkata, Bengaluru, and 8 other cities.\",\"source\":\"India's 5G Revolution: 400 Million Subscribers and Still Waiting for the Killer App\",\"sourceSlug\":\"/story/india-5g-rollout\",\"category\":\"story\"},{\"date\":\"2022-09-01\",\"title\":\"Patrol Point 15 Face-off\",\"description\":\"Fresh confrontation at Patrolling Point 15 in Gogra-Hot Springs area as China refuses to revert to pre-Galwan positions.\",\"source\":\"India-China at the Crossroads: Four Years After Galwan, the Border Remains the Flashpoint\",\"sourceSlug\":\"/story/india-china-border-tensions\",\"category\":\"story\"},{\"date\":\"2022-07-01\",\"title\":\"India-Indonesia Maritime Exercise\",\"description\":\"First bilateral maritime exercise IND-INDO CORPAT held in the Indian Ocean.\",\"source\":\"India-Indonesia: How Maritime Neighbours Are Reshaping the Indo-Pacific\",\"sourceSlug\":\"/story/india-indonesia-relations\",\"category\":\"story\"},{\"date\":\"2022-06-01\",\"title\":\"10% Blending Achieved\",\"description\":\"India reaches 10% ethanol blending milestone ahead of schedule.\",\"source\":\"E20 Backlash: India's Ethanol Push and the Consumer Revolt That Followed\",\"sourceSlug\":\"/story/ethanol-backlash\",\"category\":\"story\"},{\"date\":\"2022-06-01\",\"title\":\"FTA Talks Relaunched\",\"description\":\"EU-India FTA negotiations relaunched after 9 years. Trade and Technology Council (TTC) also established.\",\"source\":\"India and Europe: A Strategic Partnership Searching for Substance\",\"sourceSlug\":\"/story/india-europe-relations\",\"category\":\"story\"},{\"date\":\"2022-05-04\",\"title\":\"Unscheduled Rate Hike\",\"description\":\"RBI hikes repo rate by 40 bps in an unscheduled meeting to 4.40%, starting the tightening cycle.\",\"source\":\"RBI Repo Rate: Decoding Monetary Policy in a Changing Economy\",\"sourceSlug\":\"/story/rbi-repo-rate\",\"category\":\"story\"},{\"date\":\"2022-05-04\",\"title\":\"Unscheduled Rate Hike\",\"description\":\"RBI hikes repo rate by 40 bps in an unscheduled meeting to 4.40%, starting the tightening cycle.\",\"source\":\"RBI Monetary Policy Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2022-04-01\",\"title\":\"Applications Open\",\"description\":\"Semiconductor India Programme invites applications from companies to set up fabrication units.\",\"source\":\"India's ₹1.2 Lakh Crore Semiconductor Push: Can the Dream Take Silicon?\",\"sourceSlug\":\"/story/semiconductor-pli\",\"category\":\"story\"},{\"date\":\"2022-04-01\",\"title\":\"Applications Open\",\"description\":\"Semiconductor India Programme invites applications from companies to set up fabrication units.\",\"source\":\"India's Semiconductor Push\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2022-03-22\",\"title\":\"Jal Shakti Abhiyan Intensified\",\"description\":\"Government launches intensified groundwater conservation mission under Jal Shakti Abhiyan.\",\"source\":\"India's Groundwater Crisis: 62% of Districts Sound the Alarm\",\"sourceSlug\":\"/story/groundwater-depletion\",\"category\":\"story\"},{\"date\":\"2022-03-22\",\"title\":\"Jal Shakti Abhiyan Intensified\",\"description\":\"Government launches intensified groundwater conservation mission under Jal Shakti Abhiyan.\",\"source\":\"India's Groundwater Crisis Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2022-03-08\",\"title\":\"Anganwadi Worker Honorarium Revised\",\"description\":\"Government increases anganwadi worker honorarium to ₹10,000/month amidst nationwide protests.\",\"source\":\"Anganwadi Centres: India's Frontline Nutrition Workers Are Burning Out\",\"sourceSlug\":\"/story/anganwadi-icds\",\"category\":\"story\"},{\"date\":\"2022-03-08\",\"title\":\"Anganwadi Worker Honorarium Revised\",\"description\":\"Government increases anganwadi worker honorarium to ₹10,000/month amidst nationwide protests.\",\"source\":\"ICDS — India's Nutrition Programme Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2022-02-24\",\"title\":\"Ukraine War Begins\",\"description\":\"Russia invades Ukraine. India abstains from UN resolutions condemning Russia, increases oil imports from 2% to 35% of total crude imports.\",\"source\":\"India-Russia: The Enduring Partnership Tested by War and Realignment\",\"sourceSlug\":\"/story/india-russia-relations\",\"category\":\"story\"},{\"date\":\"2022-01-13\",\"title\":\"FTA Negotiations Launch\",\"description\":\"India-UK Free Trade Agreement negotiations formally launched with an aim to conclude by Diwali 2022 (missed).\",\"source\":\"India-UK Relations: Beyond Colonial History to a Modern Strategic Partnership\",\"sourceSlug\":\"/story/india-uk-relations\",\"category\":\"story\"},{\"date\":\"2021-12-15\",\"title\":\"₹76,000 Crore PLI Announced\",\"description\":\"Government approves ₹76,000 crore PLI scheme for semiconductor and display manufacturing.\",\"source\":\"India's ₹1.2 Lakh Crore Semiconductor Push: Can the Dream Take Silicon?\",\"sourceSlug\":\"/story/semiconductor-pli\",\"category\":\"story\"},{\"date\":\"2021-12-15\",\"title\":\"₹76,000 Crore PLI Announced\",\"description\":\"Government approves ₹76,000 crore PLI scheme for semiconductor and display manufacturing.\",\"source\":\"India's Semiconductor Push\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2021-11-02\",\"title\":\"COP26 Net Zero Pledge\",\"description\":\"PM Modi announces India's net zero by 2070 target at COP26 in Glasgow, along with 500 GW RE by 2030.\",\"source\":\"India's ₹11 Lakh Crore Climate Finance Challenge\",\"sourceSlug\":\"/story/climate-finance\",\"category\":\"story\"},{\"date\":\"2021-11-02\",\"title\":\"COP26 Net Zero Pledge\",\"description\":\"PM Modi announces India's net zero by 2070 target at COP26 in Glasgow, along with 500 GW RE by 2030.\",\"source\":\"India's Climate Action Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2021-09-27\",\"title\":\"Ayushman Bharat Digital Mission\",\"description\":\"National Digital Health Mission links AB-PMJAY to interoperable digital health records via Ayushman Bharat Health Account (ABHA).\",\"source\":\"Ayushman Bharat: India's ₹30,000 Crore Bet on Universal Health Coverage\",\"sourceSlug\":\"/story/ayushman-bharat\",\"category\":\"story\"},{\"date\":\"2021-08-15\",\"title\":\"Spectrum Allocation Completed\",\"description\":\"DoT completes allocation of 5G spectrum to winning bidders — Jio, Airtel, Vi, and Adani Data Networks — across 22 circles.\",\"source\":\"India's 5G Revolution: 400 Million Subscribers and Still Waiting for the Killer App\",\"sourceSlug\":\"/story/india-5g-rollout\",\"category\":\"story\"},{\"date\":\"2021-06-09\",\"title\":\"PLI ACC Battery Storage Announced\",\"description\":\"Government approves Production Linked Incentive scheme for Advanced Chemistry Cell battery storage with ₹18,100 crore outlay to boost domestic manufacturing.\",\"source\":\"India's EV Paradox: Rising Sales, Stalled Charging, and the ₹4 Lakh Crore Battery Import Bill\",\"sourceSlug\":\"/story/india-ev-paradox\",\"category\":\"story\"},{\"date\":\"2021-05-12\",\"title\":\"PLI Scheme Expansion\",\"description\":\"India expands PLI schemes to 14 sectors with ₹1.97 lakh crore outlay to attract manufacturing investments.\",\"source\":\"The Great Supply Chain Shift: Can India Capture the China+1 Opportunity?\",\"sourceSlug\":\"/story/supply-chain-shift\",\"category\":\"story\"},{\"date\":\"2021-05-12\",\"title\":\"PLI Scheme Expansion\",\"description\":\"India expands PLI schemes to 14 sectors with ₹1.97 lakh crore outlay to attract manufacturing investments.\",\"source\":\"India's Supply Chain Transformation\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2021-05-04\",\"title\":\"2030 Roadmap\",\"description\":\"India and UK adopt the 2030 Roadmap — a Comprehensive Strategic Partnership with 10-year targets across trade, defence, health, and climate.\",\"source\":\"India-UK Relations: Beyond Colonial History to a Modern Strategic Partnership\",\"sourceSlug\":\"/story/india-uk-relations\",\"category\":\"story\"},{\"date\":\"2021-04-06\",\"title\":\"Vienna Talks Begin\",\"description\":\"Iran and P5+1 begin negotiations to restore JCPOA compliance in Vienna.\",\"source\":\"US-Iran Relations: From Maximum Pressure to Nuclear Negotiations\",\"sourceSlug\":\"/story/us-iran-relations\",\"category\":\"story\"},{\"date\":\"2021-04-01\",\"title\":\"₹1,000 Crore+ Annual Threshold Crossed\",\"description\":\"Annual electoral bond sales cross ₹1,000 crore for the first time, driven by corporate donations.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2021-03-01\",\"title\":\"2021 Spectrum Auctions Conclude\",\"description\":\"DoT conducts India's largest-ever spectrum auction, raising ₹4.3 lakh crore. Jio and Airtel acquire substantial 700 MHz, 3.5 GHz, and 26 GHz spectrum.\",\"source\":\"India's 5G Revolution: 400 Million Subscribers and Still Waiting for the Killer App\",\"sourceSlug\":\"/story/india-5g-rollout\",\"category\":\"story\"},{\"date\":\"2021-02-01\",\"title\":\"Budget Allocation Boosted\",\"description\":\"Education budget increased by 20% to ₹93,224 crore in FY2021-22.\",\"source\":\"Education Budget: Widening Gap Between Spending and Learning Outcomes\",\"sourceSlug\":\"/story/education-budget\",\"category\":\"story\"},{\"date\":\"2021-02-01\",\"title\":\"Budget Allocation Boosted\",\"description\":\"Education budget increased by 20% to ₹93,224 crore in FY2021-22.\",\"source\":\"Education Policy & Budget Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2020-09-01\",\"title\":\"Global Cancer Cases Cross 19 Million\",\"description\":\"GLOBOCAN 2020 reports 19.3 million new cancer cases and 10 million deaths, with breast cancer overtaking lung as most commonly diagnosed.\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"2020-07-30\",\"title\":\"NEP 2020 Approved\",\"description\":\"National Education Policy 2020 approved by Union Cabinet, replacing the 34-year-old NPE 1986.\",\"source\":\"Education Budget: Widening Gap Between Spending and Learning Outcomes\",\"sourceSlug\":\"/story/education-budget\",\"category\":\"story\"},{\"date\":\"2020-07-30\",\"title\":\"NEP 2020 Approved\",\"description\":\"National Education Policy 2020 replaces NPE 1986, introducing 5+3+3+4 structure, vocational integration, and mother tongue instruction.\",\"source\":\"India's Education Paradox: Rising Enrolment, Falling Learning — What Went Wrong?\",\"sourceSlug\":\"/story/indian-education-crisis\",\"category\":\"story\"},{\"date\":\"2020-07-30\",\"title\":\"NEP 2020 Approved\",\"description\":\"National Education Policy 2020 approved by Union Cabinet, replacing the 34-year-old NPE 1986.\",\"source\":\"Education Policy & Budget Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2020-07-15\",\"title\":\"India-EU Summit Revival\",\"description\":\"India-EU Leaders' Summit held virtually, agreeing to resume FTA negotiations and launch a Connectivity Partnership.\",\"source\":\"India and Europe: A Strategic Partnership Searching for Substance\",\"sourceSlug\":\"/story/india-europe-relations\",\"category\":\"story\"},{\"date\":\"2020-06-15\",\"title\":\"Galwan Valley Clash\",\"description\":\"Violent clash at Galwan Valley leaves 20 Indian and 45+ Chinese soldiers dead — worst conflict since 1962.\",\"source\":\"India-China at the Crossroads: Four Years After Galwan, the Border Remains the Flashpoint\",\"sourceSlug\":\"/story/india-china-border-tensions\",\"category\":\"story\"},{\"date\":\"2020-06-15\",\"title\":\"Galwan Valley Clash\",\"description\":\"Deadliest India-China military clash in 45 years — 20 Indian and at least 45 Chinese soldiers killed in hand-to-hand combat in the Galwan Valley.\",\"source\":\"India-China: Two Asian Giants in an Era of Mistrust and Strategic Rivalry\",\"sourceSlug\":\"/story/india-china-relations\",\"category\":\"story\"},{\"date\":\"2020-04-01\",\"title\":\"COVID-19 Surge\",\"description\":\"Demand for work surges 40% during pandemic.\",\"source\":\"MGNREGA Completes 20 Years: A Data-Driven Assessment of Rural Employment\",\"sourceSlug\":\"/story/mgnrega-reform\",\"category\":\"story\"},{\"date\":\"2020-04-01\",\"title\":\"Post-COVID Supply Chain Rethink\",\"description\":\"COVID-19 disruptions expose over-reliance on Chinese supply chains, triggering global diversification strategies.\",\"source\":\"The Great Supply Chain Shift: Can India Capture the China+1 Opportunity?\",\"sourceSlug\":\"/story/supply-chain-shift\",\"category\":\"story\"},{\"date\":\"2020-04-01\",\"title\":\"COVID-19 Surge\",\"description\":\"Demand for work surges 40% during pandemic.\",\"source\":\"MGNREGA — Two Decades of Rural Employment\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2020-04-01\",\"title\":\"Post-COVID Supply Chain Rethink\",\"description\":\"COVID-19 disruptions expose over-reliance on Chinese supply chains, triggering global diversification strategies.\",\"source\":\"India's Supply Chain Transformation\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2020-03-01\",\"title\":\"ICMR COVID-19 Testing Database\",\"description\":\"ICMR begins aggregating nationwide COVID-19 testing data, collecting Aadhaar and passport details for result delivery.\",\"source\":\"81.5 Crore Aadhaar Records Exposed: Inside India's Biggest Data Breach\",\"sourceSlug\":\"/story/81-crore-data-breach\",\"category\":\"story\"},{\"date\":\"2020-03-01\",\"title\":\"ICMR COVID-19 Testing Database\",\"description\":\"ICMR begins aggregating nationwide COVID-19 testing data, collecting Aadhaar and passport details for result delivery.\",\"source\":\"The 81.5 Crore Aadhaar Data Breach\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2020-02-01\",\"title\":\"Revised Guidelines\",\"description\":\"Government revises PMFBY guidelines to speed up claims.\",\"source\":\"PM Fasal Bima Yojana: The Claims That Never Reached Farmers\",\"sourceSlug\":\"/story/pm-fasal-bima-claims\",\"category\":\"story\"},{\"date\":\"2020-02-01\",\"title\":\"Revised Guidelines\",\"description\":\"Government revises PMFBY guidelines to speed up claims.\",\"source\":\"PMFBY — Crop Insurance in India\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2020-01-03\",\"title\":\"Soleimani Assassinated\",\"description\":\"US drone strike kills Quds Force commander Qasem Soleimani in Baghdad, escalating tensions.\",\"source\":\"US-Iran Relations: From Maximum Pressure to Nuclear Negotiations\",\"sourceSlug\":\"/story/us-iran-relations\",\"category\":\"story\"},{\"date\":\"2020-01-01\",\"title\":\"UPI 2.0 Released\",\"description\":\"Feature phone support added via USSD 2.0.\",\"source\":\"Digital Payments in Rural India: UPI's Unseen Revolution\",\"sourceSlug\":\"/story/digital-payments-boom\",\"category\":\"story\"},{\"date\":\"2020-01-01\",\"title\":\"ONORC Launched Nationally\",\"description\":\"One Nation One Ration Card scheme launched to enable interstate portability of ration benefits.\",\"source\":\"Digitizing PDS: How Technology Plugged the Leakage in India's Food Security Net\",\"sourceSlug\":\"/story/ration-digitization\",\"category\":\"story\"},{\"date\":\"2020-01-01\",\"title\":\"UPI 2.0 Released\",\"description\":\"Feature phone support added via USSD 2.0.\",\"source\":\"UPI — The Digital Payments Revolution\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2020-01-01\",\"title\":\"ONORC Launched Nationally\",\"description\":\"One Nation One Ration Card scheme launched to enable interstate portability of ration benefits.\",\"source\":\"PDS Digitization Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2019-12-11\",\"title\":\"PDP Bill Introduced\",\"description\":\"Personal Data Protection Bill 2019 introduced in Lok Sabha, later referred to Joint Parliamentary Committee.\",\"source\":\"Digital Personal Data Protection: India's Privacy Law Comes of Age\",\"sourceSlug\":\"/story/dpdp-bill\",\"category\":\"story\"},{\"date\":\"2019-12-11\",\"title\":\"PDP Bill Introduced\",\"description\":\"Personal Data Protection Bill 2019 introduced in Lok Sabha, later referred to Joint Parliamentary Committee.\",\"source\":\"India's Data Protection Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2019-09-20\",\"title\":\"Corporate Tax Rate Cut\",\"description\":\"Government slashes corporate tax rate from 30% to 22%, reducing government revenue by ₹1.45 lakh crore annually and benefiting large corporations.\",\"source\":\"Income Inequality in India: The Top 1% Now Owns 40% of the Wealth\",\"sourceSlug\":\"/story/income-inequality-india\",\"category\":\"story\"},{\"date\":\"2019-06-28\",\"title\":\"Chennai Water Crisis\",\"description\":\"Chennai runs out of water, with reservoirs drying up, highlighting the severity of India's groundwater crisis.\",\"source\":\"India's Groundwater Crisis: 62% of Districts Sound the Alarm\",\"sourceSlug\":\"/story/groundwater-depletion\",\"category\":\"story\"},{\"date\":\"2019-06-28\",\"title\":\"Chennai Water Crisis\",\"description\":\"Chennai runs out of water, with reservoirs drying up, highlighting the severity of India's groundwater crisis.\",\"source\":\"India's Groundwater Crisis Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2019-04-01\",\"title\":\"FAME India Scheme Phase II\",\"description\":\"Phase II launched with ₹10,000 crore outlay over three years, with increased focus on public transport, 3-wheelers, and 4-wheelers for commercial use.\",\"source\":\"India's EV Paradox: Rising Sales, Stalled Charging, and the ₹4 Lakh Crore Battery Import Bill\",\"sourceSlug\":\"/story/india-ev-paradox\",\"category\":\"story\"},{\"date\":\"2019-04-01\",\"title\":\"Expansion to 33 States\",\"description\":\"Scheme operationalized across 33 states and UTs. West Bengal, Odisha, Delhi, and Telangana opt out citing existing state schemes.\",\"source\":\"Ayushman Bharat: India's ₹30,000 Crore Bet on Universal Health Coverage\",\"sourceSlug\":\"/story/ayushman-bharat\",\"category\":\"story\"},{\"date\":\"2019-04-01\",\"title\":\"First Post-Lok Sabha Tranche\",\"description\":\"Bonds sold after the 2019 Lok Sabha elections. Total donations begin to accelerate significantly.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2019-01-01\",\"title\":\"103rd Amendment Passed\",\"description\":\"Parliament passes 103rd Amendment providing 10% EWS reservation.\",\"source\":\"Who Really Gets the EWS Quota? An Investigation into UPSC's 104 Selections\",\"sourceSlug\":\"/story/ews-quota-upsc-investigation\",\"category\":\"story\"},{\"date\":\"2018-10-05\",\"title\":\"S-400 Deal Signed\",\"description\":\"India signs $5.4 billion deal for five S-400 Triumf air defence systems, despite US CAATSA sanctions threat.\",\"source\":\"India-Russia: The Enduring Partnership Tested by War and Realignment\",\"sourceSlug\":\"/story/india-russia-relations\",\"category\":\"story\"},{\"date\":\"2018-09-23\",\"title\":\"AB-PMJAY Launched\",\"description\":\"PM launches Ayushman Bharat PM-JAY covering 10.74 crore poor and vulnerable families with ₹5 lakh annual health cover.\",\"source\":\"Ayushman Bharat: India's ₹30,000 Crore Bet on Universal Health Coverage\",\"sourceSlug\":\"/story/ayushman-bharat\",\"category\":\"story\"},{\"date\":\"2018-09-06\",\"title\":\"First 2+2 Dialogue\",\"description\":\"First India-US 2+2 Ministerial Dialogue (Defence + External Affairs) held in New Delhi.\",\"source\":\"India-US Relations: From Nuclear Deal to Critical Technology Partnership\",\"sourceSlug\":\"/story/india-us-relations\",\"category\":\"story\"},{\"date\":\"2018-07-27\",\"title\":\"Srikrishna Committee Report\",\"description\":\"BN Srikrishna-led committee submits draft Personal Data Protection Bill to the government.\",\"source\":\"Digital Personal Data Protection: India's Privacy Law Comes of Age\",\"sourceSlug\":\"/story/dpdp-bill\",\"category\":\"story\"},{\"date\":\"2018-07-27\",\"title\":\"Srikrishna Committee Report\",\"description\":\"BN Srikrishna-led committee submits draft Personal Data Protection Bill to the government.\",\"source\":\"India's Data Protection Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2018-06-01\",\"title\":\"20% Target Set\",\"description\":\"National Policy on Biofuels sets 20% ethanol blending target by 2030.\",\"source\":\"E20 Backlash: India's Ethanol Push and the Consumer Revolt That Followed\",\"sourceSlug\":\"/story/ethanol-backlash\",\"category\":\"story\"},{\"date\":\"2018-05-30\",\"title\":\"Defence Cooperation Agreement\",\"description\":\"Comprehensive defence cooperation agreement signed during PM Modi's visit to Jakarta.\",\"source\":\"India-Indonesia: How Maritime Neighbours Are Reshaping the Indo-Pacific\",\"sourceSlug\":\"/story/india-indonesia-relations\",\"category\":\"story\"},{\"date\":\"2018-05-08\",\"title\":\"US Withdraws from JCPOA\",\"description\":\"President Trump withdraws US from the nuclear deal, reimposing sweeping sanctions on Iran.\",\"source\":\"US-Iran Relations: From Maximum Pressure to Nuclear Negotiations\",\"sourceSlug\":\"/story/us-iran-relations\",\"category\":\"story\"},{\"date\":\"2018-03-01\",\"title\":\"First Tranche Sold\",\"description\":\"First tranche of electoral bonds goes on sale. Bonds available for 10 days in January, April, July, and October each year.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2018-01-02\",\"title\":\"Scheme Notified\",\"description\":\"Government notifies the Electoral Bond Scheme, 2018. Bonds available for purchase at SBI branches in phases.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2018-01-01\",\"title\":\"Digitization Push Begins\",\"description\":\"Government mandates Aadhaar seeding of PDS databases and deploys ePoS devices at fair price shops.\",\"source\":\"Digitizing PDS: How Technology Plugged the Leakage in India's Food Security Net\",\"sourceSlug\":\"/story/ration-digitization\",\"category\":\"story\"},{\"date\":\"2018-01-01\",\"title\":\"Digitization Push Begins\",\"description\":\"Government mandates Aadhaar seeding of PDS databases and deploys ePoS devices at fair price shops.\",\"source\":\"PDS Digitization Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2017-12-01\",\"title\":\"POSHAN Abhiyaan Launched\",\"description\":\"National Nutrition Mission (POSHAN Abhiyaan) launched to combat malnutrition with targeted interventions.\",\"source\":\"Anganwadi Centres: India's Frontline Nutrition Workers Are Burning Out\",\"sourceSlug\":\"/story/anganwadi-icds\",\"category\":\"story\"},{\"date\":\"2017-12-01\",\"title\":\"POSHAN Abhiyaan Launched\",\"description\":\"National Nutrition Mission (POSHAN Abhiyaan) launched to combat malnutrition with targeted interventions.\",\"source\":\"ICDS — India's Nutrition Programme Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2017-08-24\",\"title\":\"Right to Privacy Judgment\",\"description\":\"Supreme Court in Justice K.S. Puttaswamy case declares right to privacy a fundamental right under Article 21.\",\"source\":\"Digital Personal Data Protection: India's Privacy Law Comes of Age\",\"sourceSlug\":\"/story/dpdp-bill\",\"category\":\"story\"},{\"date\":\"2017-08-24\",\"title\":\"Right to Privacy Judgment\",\"description\":\"Supreme Court in Justice K.S. Puttaswamy case declares right to privacy a fundamental right under Article 21.\",\"source\":\"India's Data Protection Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2017-07-12\",\"title\":\"Electoral Bonds Scheme Proposed\",\"description\":\"Finance Minister Arun Jaitley introduces Electoral Bond scheme in the Union Budget 2017-18 as an alternative to cash donations.\",\"source\":\"Electoral Bonds: The ₹12,769 Crore Anonymous Donation Scheme the Supreme Court Struck Down\",\"sourceSlug\":\"/story/electoral-bonds\",\"category\":\"story\"},{\"date\":\"2017-07-01\",\"title\":\"GST Implementation\",\"description\":\"GST with multiple slabs and regressive structure disproportionately impacts lower-income households who spend a higher share of income on essentials.\",\"source\":\"Income Inequality in India: The Top 1% Now Owns 40% of the Wealth\",\"sourceSlug\":\"/story/income-inequality-india\",\"category\":\"story\"},{\"date\":\"2017-06-16\",\"title\":\"Doklam Standoff\",\"description\":\"Chinese PLA builds road in Doklam area claimed by Bhutan. 73-day standoff ensues with Indian troops.\",\"source\":\"India-China at the Crossroads: Four Years After Galwan, the Border Remains the Flashpoint\",\"sourceSlug\":\"/story/india-china-border-tensions\",\"category\":\"story\"},{\"date\":\"2017-06-16\",\"title\":\"Doklam Standoff\",\"description\":\"Chinese and Indian troops face off for 73 days in Doklam over Chinese road construction in Bhutan-India tri-junction.\",\"source\":\"India-China: Two Asian Giants in an Era of Mistrust and Strategic Rivalry\",\"sourceSlug\":\"/story/india-china-relations\",\"category\":\"story\"},{\"date\":\"2017-05-30\",\"title\":\"Cancer Resolution WHA70.12\",\"description\":\"World Health Assembly adopts resolution on cancer prevention and control in the context of an integrated approach to NCDs.\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"2016-10-04\",\"title\":\"Monetary Policy Committee Formed\",\"description\":\"MPC established under amended RBI Act with inflation targeting mandate of 4% ±2%.\",\"source\":\"RBI Repo Rate: Decoding Monetary Policy in a Changing Economy\",\"sourceSlug\":\"/story/rbi-repo-rate\",\"category\":\"story\"},{\"date\":\"2016-10-04\",\"title\":\"Monetary Policy Committee Formed\",\"description\":\"MPC established under amended RBI Act with inflation targeting mandate of 4% ±2%.\",\"source\":\"RBI Monetary Policy Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2016-08-29\",\"title\":\"Logistics Agreement Signed\",\"description\":\"LEMOA (Logistics Exchange Memorandum of Agreement) signed, allowing mutual access to military bases for supplies.\",\"source\":\"India-US Relations: From Nuclear Deal to Critical Technology Partnership\",\"sourceSlug\":\"/story/india-us-relations\",\"category\":\"story\"},{\"date\":\"2016-04-11\",\"title\":\"UPI Launched\",\"description\":\"NPCI launches Unified Payments Interface.\",\"source\":\"Digital Payments in Rural India: UPI's Unseen Revolution\",\"sourceSlug\":\"/story/digital-payments-boom\",\"category\":\"story\"},{\"date\":\"2016-04-11\",\"title\":\"UPI Launched\",\"description\":\"NPCI launches Unified Payments Interface.\",\"source\":\"UPI — The Digital Payments Revolution\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2016-01-13\",\"title\":\"PMFBY Launched\",\"description\":\"PM Fasal Bima Yojana launched to replace existing crop insurance schemes.\",\"source\":\"PM Fasal Bima Yojana: The Claims That Never Reached Farmers\",\"sourceSlug\":\"/story/pm-fasal-bima-claims\",\"category\":\"story\"},{\"date\":\"2016-01-13\",\"title\":\"PMFBY Launched\",\"description\":\"PM Fasal Bima Yojana launched to replace existing crop insurance schemes.\",\"source\":\"PMFBY — Crop Insurance in India\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2015-12-12\",\"title\":\"Paris Agreement Signed\",\"description\":\"India signs Paris Agreement, commits to reducing emission intensity by 33-35% by 2030 from 2005 levels.\",\"source\":\"India's ₹11 Lakh Crore Climate Finance Challenge\",\"sourceSlug\":\"/story/climate-finance\",\"category\":\"story\"},{\"date\":\"2015-12-12\",\"title\":\"Paris Agreement Signed\",\"description\":\"India signs Paris Agreement, commits to reducing emission intensity by 33-35% by 2030 from 2005 levels.\",\"source\":\"India's Climate Action Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2015-07-14\",\"title\":\"JCPOA Signed\",\"description\":\"Iran and P5+1 sign Joint Comprehensive Plan of Action, limiting Iran's nuclear program in exchange for sanctions relief.\",\"source\":\"US-Iran Relations: From Maximum Pressure to Nuclear Negotiations\",\"sourceSlug\":\"/story/us-iran-relations\",\"category\":\"story\"},{\"date\":\"2015-06-01\",\"title\":\"Atal Bhujal Yojana Launched\",\"description\":\"Central scheme for sustainable groundwater management with community participation launched with World Bank support.\",\"source\":\"India's Groundwater Crisis: 62% of Districts Sound the Alarm\",\"sourceSlug\":\"/story/groundwater-depletion\",\"category\":\"story\"},{\"date\":\"2015-06-01\",\"title\":\"Atal Bhujal Yojana Launched\",\"description\":\"Central scheme for sustainable groundwater management with community participation launched with World Bank support.\",\"source\":\"India's Groundwater Crisis Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2015-04-01\",\"title\":\"FAME India Scheme Phase I\",\"description\":\"Faster Adoption and Manufacturing of (Hybrid &) Electric Vehicles scheme launched with ₹895 crore outlay for demand incentives, pilot projects, and charging infrastructure.\",\"source\":\"India's EV Paradox: Rising Sales, Stalled Charging, and the ₹4 Lakh Crore Battery Import Bill\",\"sourceSlug\":\"/story/india-ev-paradox\",\"category\":\"story\"},{\"date\":\"2014-05-26\",\"title\":\"Modi Doctrine Emerges\",\"description\":\"Modi government prioritises active neighbourhood diplomacy, Act East, and strategic partnerships with US, Japan, Australia, and Israel.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"2014-01-01\",\"title\":\"Consumption Inequality Gap Widens\",\"description\":\"NSSO data shows consumption inequality rising as urban-rural divide expands with services-led growth.\",\"source\":\"Income Inequality in India: The Top 1% Now Owns 40% of the Wealth\",\"sourceSlug\":\"/story/income-inequality-india\",\"category\":\"story\"},{\"date\":\"2013-09-10\",\"title\":\"National Food Security Act\",\"description\":\"NFSA enacted, legalising right to food and covering 67% of India's population for subsidized food grains.\",\"source\":\"Digitizing PDS: How Technology Plugged the Leakage in India's Food Security Net\",\"sourceSlug\":\"/story/ration-digitization\",\"category\":\"story\"},{\"date\":\"2013-09-10\",\"title\":\"National Food Security Act\",\"description\":\"NFSA enacted, legalising right to food and covering 67% of India's population for subsidized food grains.\",\"source\":\"PDS Digitization Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2013-09-01\",\"title\":\"Enhanced Wage Structure\",\"description\":\"Wage rates revised with CPI-AL linkage.\",\"source\":\"MGNREGA Completes 20 Years: A Data-Driven Assessment of Rural Employment\",\"sourceSlug\":\"/story/mgnrega-reform\",\"category\":\"story\"},{\"date\":\"2013-09-01\",\"title\":\"Enhanced Wage Structure\",\"description\":\"Wage rates revised with CPI-AL linkage.\",\"source\":\"MGNREGA — Two Decades of Rural Employment\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2013-06-01\",\"title\":\"FTA Talks Suspended\",\"description\":\"Negotiations collapse over disagreements on tariffs, data security, and market access for Indian professionals and EU wines and automobiles.\",\"source\":\"India and Europe: A Strategic Partnership Searching for Substance\",\"sourceSlug\":\"/story/india-europe-relations\",\"category\":\"story\"},{\"date\":\"2013-04-15\",\"title\":\"Depsang Standoff\",\"description\":\"Chinese troops penetrate 19 km into Indian territory in the Depsang Valley, beginning a pattern of aggressive PLA patrolling.\",\"source\":\"India-China: Two Asian Giants in an Era of Mistrust and Strategic Rivalry\",\"sourceSlug\":\"/story/india-china-relations\",\"category\":\"story\"},{\"date\":\"2013-01-01\",\"title\":\"NEMMP Launched\",\"description\":\"National Electric Mobility Mission Plan 2020 launched targeting 6-7 million EV sales by 2020, with a ₹23,000 crore investment roadmap.\",\"source\":\"India's EV Paradox: Rising Sales, Stalled Charging, and the ₹4 Lakh Crore Battery Import Bill\",\"sourceSlug\":\"/story/india-ev-paradox\",\"category\":\"story\"},{\"date\":\"2012-02-01\",\"title\":\"National Aquifer Mapping Launched\",\"description\":\"CGWB launches NAQUIM (National Aquifer Mapping and Management) programme to map groundwater resources.\",\"source\":\"India's Groundwater Crisis: 62% of Districts Sound the Alarm\",\"sourceSlug\":\"/story/groundwater-depletion\",\"category\":\"story\"},{\"date\":\"2012-02-01\",\"title\":\"National Aquifer Mapping Launched\",\"description\":\"CGWB launches NAQUIM (National Aquifer Mapping and Management) programme to map groundwater resources.\",\"source\":\"India's Groundwater Crisis Timeline\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2011-11-01\",\"title\":\"Supreme Court Upholds Convictions\",\"description\":\"Prithpal Singh vs State of Punjab — CBI evidence of systematic extrajudicial executions.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2009-04-01\",\"title\":\"RTE Act Comes Into Force\",\"description\":\"Right to Education Act operationalises Article 21A, mandating free schooling, no-detention policy, and 25% reservation for disadvantaged groups in private schools.\",\"source\":\"India's Education Paradox: Rising Enrolment, Falling Learning — What Went Wrong?\",\"sourceSlug\":\"/story/indian-education-crisis\",\"category\":\"story\"},{\"date\":\"2008-10-08\",\"title\":\"NSG Waiver\",\"description\":\"Nuclear Suppliers Group grants India a special waiver to engage in civilian nuclear trade despite not signing the NPT.\",\"source\":\"India-US Relations: From Nuclear Deal to Critical Technology Partnership\",\"sourceSlug\":\"/story/india-us-relations\",\"category\":\"story\"},{\"date\":\"2008-04-01\",\"title\":\"Phase 1 Completion\",\"description\":\"Scheme covers 200 most backward districts.\",\"source\":\"MGNREGA Completes 20 Years: A Data-Driven Assessment of Rural Employment\",\"sourceSlug\":\"/story/mgnrega-reform\",\"category\":\"story\"},{\"date\":\"2008-04-01\",\"title\":\"Phase 1 Completion\",\"description\":\"Scheme covers 200 most backward districts.\",\"source\":\"MGNREGA — Two Decades of Rural Employment\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2007-10-16\",\"title\":\"Life Sentences Upheld by High Court\",\"description\":\"Punjab & Haryana High Court enhances sentences to life imprisonment.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2007-06-01\",\"title\":\"FTA Negotiations Begin\",\"description\":\"India-EU Broad-based Trade and Investment Agreement (BTIA) negotiations formally launched.\",\"source\":\"India and Europe: A Strategic Partnership Searching for Substance\",\"sourceSlug\":\"/story/india-europe-relations\",\"category\":\"story\"},{\"date\":\"2006-03-01\",\"title\":\"Universal Coverage\",\"description\":\"ICDS expanded to cover all 6,000+ community development blocks across India.\",\"source\":\"Anganwadi Centres: India's Frontline Nutrition Workers Are Burning Out\",\"sourceSlug\":\"/story/anganwadi-icds\",\"category\":\"story\"},{\"date\":\"2006-03-01\",\"title\":\"Universal Coverage\",\"description\":\"ICDS expanded to cover all 6,000+ community development blocks across India.\",\"source\":\"ICDS — India's Nutrition Programme Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2006-02-02\",\"title\":\"MGNREGA Enacted\",\"description\":\"Parliament passes the National Rural Employment Guarantee Act.\",\"source\":\"MGNREGA Completes 20 Years: A Data-Driven Assessment of Rural Employment\",\"sourceSlug\":\"/story/mgnrega-reform\",\"category\":\"story\"},{\"date\":\"2006-02-02\",\"title\":\"MGNREGA Enacted\",\"description\":\"Parliament passes the National Rural Employment Guarantee Act.\",\"source\":\"MGNREGA — Two Decades of Rural Employment\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"2006-01-01\",\"title\":\"Inequality Begins Rising\",\"description\":\"Post-liberalisation growth accelerates but benefits accrue disproportionately to top income deciles. Gini starts multi-year climb from 0.33.\",\"source\":\"Income Inequality in India: The Top 1% Now Owns 40% of the Wealth\",\"sourceSlug\":\"/story/income-inequality-india\",\"category\":\"story\"},{\"date\":\"2005-11-18\",\"title\":\"Six Policemen Convicted\",\"description\":\"Patiala court convicts six police officials for abduction and murder.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"2005-11-01\",\"title\":\"Strategic Partnership\",\"description\":\"India-Indonesia relations upgraded to Strategic Partnership during PM Manmohan Singh's visit.\",\"source\":\"India-Indonesia: How Maritime Neighbours Are Reshaping the Indo-Pacific\",\"sourceSlug\":\"/story/india-indonesia-relations\",\"category\":\"story\"},{\"date\":\"2005-07-18\",\"title\":\"India-US Civil Nuclear Deal\",\"description\":\"PM Manmohan Singh and President Bush announce civil nuclear deal, ending India's nuclear isolation and transforming US-India relationship.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"2005-07-18\",\"title\":\"Civil Nuclear Deal\",\"description\":\"US-India Civil Nuclear Cooperation Agreement announced by PM Manmohan Singh and President George W. Bush, ending India's nuclear isolation.\",\"source\":\"India-US Relations: From Nuclear Deal to Critical Technology Partnership\",\"sourceSlug\":\"/story/india-us-relations\",\"category\":\"story\"},{\"date\":\"2005-05-25\",\"title\":\"WHO Cancer Control Resolution\",\"description\":\"World Health Assembly adopts resolution WHA58.22 on cancer prevention and control, urging member states to develop national cancer plans.\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"2004-11-01\",\"title\":\"Strategic Partnership\",\"description\":\"India and the EU establish a Strategic Partnership during the 5th India-EU Summit in The Hague.\",\"source\":\"India and Europe: A Strategic Partnership Searching for Substance\",\"sourceSlug\":\"/story/india-europe-relations\",\"category\":\"story\"},{\"date\":\"2004-09-01\",\"title\":\"Strategic Partnership\",\"description\":\"India-UK relations upgraded to Strategic Partnership with focus on defence, civil nuclear cooperation, and education.\",\"source\":\"India-UK Relations: Beyond Colonial History to a Modern Strategic Partnership\",\"sourceSlug\":\"/story/india-uk-relations\",\"category\":\"story\"},{\"date\":\"2003-01-01\",\"title\":\"EBP Programme Launched\",\"description\":\"India launches Ethanol Blended Petrol programme at 5% blending.\",\"source\":\"E20 Backlash: India's Ethanol Push and the Consumer Revolt That Followed\",\"sourceSlug\":\"/story/ethanol-backlash\",\"category\":\"story\"},{\"date\":\"2002-12-01\",\"title\":\"86th Constitutional Amendment\",\"description\":\"Article 21A inserted, making free and compulsory education a fundamental right for children aged 6-14.\",\"source\":\"India's Education Paradox: Rising Enrolment, Falling Learning — What Went Wrong?\",\"sourceSlug\":\"/story/indian-education-crisis\",\"category\":\"story\"},{\"date\":\"2000-10-03\",\"title\":\"Strategic Partnership\",\"description\":\"Declaration on Strategic Partnership signed during President Putin's visit to India.\",\"source\":\"India-Russia: The Enduring Partnership Tested by War and Realignment\",\"sourceSlug\":\"/story/india-russia-relations\",\"category\":\"story\"},{\"date\":\"1995-09-06\",\"title\":\"Khalra Abducted and Murdered\",\"description\":\"Taken by Punjab Police, tortured, killed, body disposed in Sutlej river.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"1995-01-01\",\"title\":\"Khalra Publishes Cremation Ground Findings\",\"description\":\"Documents 2,000+ unclaimed bodies cremated at municipal grounds (1984-1994).\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"1993-09-07\",\"title\":\"Peace and Tranquility Agreement\",\"description\":\"India and China sign agreement to maintain peace along LAC pending final resolution of border dispute.\",\"source\":\"India-China at the Crossroads: Four Years After Galwan, the Border Remains the Flashpoint\",\"sourceSlug\":\"/story/india-china-border-tensions\",\"category\":\"story\"},{\"date\":\"1991-01-01\",\"title\":\"Look East Policy Launched\",\"description\":\"India launches Look East policy under PM Narasimha Rao to deepen economic and strategic ties with Southeast Asia.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"1988-12-19\",\"title\":\"Rajiv Gandhi Visit\",\"description\":\"PM Rajiv Gandhi's historic visit to Beijing breaks the post-war freeze. Joint Working Group on border dispute established.\",\"source\":\"India-China: Two Asian Giants in an Era of Mistrust and Strategic Rivalry\",\"sourceSlug\":\"/story/india-china-relations\",\"category\":\"story\"},{\"date\":\"1986-08-01\",\"title\":\"National Policy on Education 1986\",\"description\":\"NPE 1986 adopted, focusing on universal access, quality improvement, and equality in education.\",\"source\":\"India's Education Paradox: Rising Enrolment, Falling Learning — What Went Wrong?\",\"sourceSlug\":\"/story/indian-education-crisis\",\"category\":\"story\"},{\"date\":\"1984-06-01\",\"title\":\"Operation Blue Star\",\"description\":\"Catalyses the Punjab insurgency.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"1981-01-01\",\"title\":\"First Global Cancer Estimates Published\",\"description\":\"IARC publishes the first GLOBOCAN global cancer incidence and mortality estimates covering 5 continents.\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"1975-10-02\",\"title\":\"ICDS Launched\",\"description\":\"Integrated Child Development Services launched as India's flagship nutrition and early childhood programme.\",\"source\":\"Anganwadi Centres: India's Frontline Nutrition Workers Are Burning Out\",\"sourceSlug\":\"/story/anganwadi-icds\",\"category\":\"story\"},{\"date\":\"1975-10-02\",\"title\":\"ICDS Launched\",\"description\":\"Integrated Child Development Services launched as India's flagship nutrition and early childhood programme.\",\"source\":\"ICDS — India's Nutrition Programme Journey\",\"sourceSlug\":null,\"category\":\"timeline\"},{\"date\":\"1971-08-09\",\"title\":\"Indo-Soviet Treaty\",\"description\":\"India signs 20-year Treaty of Peace, Friendship and Cooperation with USSR, solidifying Cold War alignment with the Soviet bloc.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"1971-08-09\",\"title\":\"Indo-Soviet Treaty\",\"description\":\"Treaty of Peace, Friendship and Cooperation signed. USSR vetoes UN resolutions on Bangladesh war and provides critical military support.\",\"source\":\"India-Russia: The Enduring Partnership Tested by War and Realignment\",\"sourceSlug\":\"/story/india-russia-relations\",\"category\":\"story\"},{\"date\":\"1965-01-01\",\"title\":\"IARC Established\",\"description\":\"WHO establishes the International Agency for Research on Cancer (IARC) in Lyon, France, to coordinate and conduct research on cancer causes.\",\"source\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\",\"sourceSlug\":\"/story/who-cancer-report-2026\",\"category\":\"story\"},{\"date\":\"1962-10-20\",\"title\":\"Sino-Indian War\",\"description\":\"China launches surprise offensive across LAC, capturing Aksai Chin. India suffers decisive military defeat.\",\"source\":\"India-China at the Crossroads: Four Years After Galwan, the Border Remains the Flashpoint\",\"sourceSlug\":\"/story/india-china-border-tensions\",\"category\":\"story\"},{\"date\":\"1962-10-20\",\"title\":\"Sino-Indian War\",\"description\":\"China launches a full-scale offensive across the McMahon Line, defeating Indian forces and annexing Aksai Chin. The war shapes bilateral relations for decades.\",\"source\":\"India-China: Two Asian Giants in an Era of Mistrust and Strategic Rivalry\",\"sourceSlug\":\"/story/india-china-relations\",\"category\":\"story\"},{\"date\":\"1955-04-18\",\"title\":\"Bandung Conference\",\"description\":\"India co-founds the Non-Aligned Movement at the Bandung Conference, emerging as a leader of the post-colonial world.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"1952-11-02\",\"title\":\"Jaswant Singh Khalra Born\",\"description\":\"Born in Khalra village, Tarn Taran district, Punjab.\",\"source\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\",\"sourceSlug\":\"/story/satluj-ban\",\"category\":\"story\"},{\"date\":\"1950-03-03\",\"title\":\"Diplomatic Ties Established\",\"description\":\"India and Indonesia establish formal diplomatic relations, with India supporting Indonesian independence.\",\"source\":\"India-Indonesia: How Maritime Neighbours Are Reshaping the Indo-Pacific\",\"sourceSlug\":\"/story/india-indonesia-relations\",\"category\":\"story\"},{\"date\":\"1950-01-26\",\"title\":\"Republic Within Commonwealth\",\"description\":\"India becomes a republic but remains a member of the Commonwealth — the first republic to do so.\",\"source\":\"India-UK Relations: Beyond Colonial History to a Modern Strategic Partnership\",\"sourceSlug\":\"/story/india-uk-relations\",\"category\":\"story\"},{\"date\":\"1947-08-15\",\"title\":\"Independent India's Foreign Policy\",\"description\":\"India gains independence with Nehru as first PM, establishing non-alignment as the cornerstone of foreign policy.\",\"source\":\"India's Foreign Policy at 80: From Non-Alignment to Multi-Alignment\",\"sourceSlug\":\"/story/indias-foreign-policy\",\"category\":\"story\"},{\"date\":\"1947-08-15\",\"title\":\"Independence\",\"description\":\"India gains independence from British rule. The India-Pakistan partition leads to the largest mass migration in history.\",\"source\":\"India-UK Relations: Beyond Colonial History to a Modern Strategic Partnership\",\"sourceSlug\":\"/story/india-uk-relations\",\"category\":\"story\"},{\"date\":\"1947-08-15\",\"title\":\"Early Diplomatic Ties\",\"description\":\"India establishes diplomatic relations with the Soviet Union days after independence. USSR supports India on Kashmir at the UN.\",\"source\":\"India-Russia: The Enduring Partnership Tested by War and Realignment\",\"sourceSlug\":\"/story/india-russia-relations\",\"category\":\"story\"}]}]]}]}]],null,\"$L1a\"]}]\n14:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L1b\",null,{\"children\":\"$L1c\"}],null],[\"$\",\"$L1d\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$17\",null,{\"fallback\":null,\"children\":\"$L1e\"}]}]}]]}]\n1f:I[24431,[],\"OutletBoundary\"]\n21:I[15278,[],\"AsyncMetadataOutlet\"]\n1a:[\"$\",\"$L1f\",null,{\"children\":[\"$L20\",[\"$\",\"$L21\",null,{\"promise\":\"$@22\"}]]}]\n1c:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n20:null\n22:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"Timeline — The Breakdown — The Breakdown\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Explore all major events across stories, policies, and entities on The Breakdown.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:title\",\"content\":\"Timeline — The Breakdown\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:description\",\"content\":\"Explore all major events across stories, policies, and entities.\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:url