emibold border bg-gray-800/50 text-gray-300 border border-gray-700 \",\"children\":[false,false,\"health\"]}]}],[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-white group-hover:text-amber-400 transition-colors mb-2 leading-snug\",\"children\":\"Global Cancer Crisis: WHO Report Warns 35 Million Cases Per Year by 2050 Without Urgent Action\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-400 mb-4 line-clamp-2\",\"children\":\"The World Health Organization's Global Status Report on Cancer 2026 reveals 20.6 million new diagnoses and nearly 10 million deaths in 2024 — with projections escalating to 35 million annual cases by 2050. Lung, breast, and colorectal cancers dominate the global burden while vast disparities persist: 87% breast cancer survival in high-income countries versus 42% in low-income nations. The report's seven recommendations call for three strategic shifts: better capabilities, better protections, and better value in cancer care worldwide.\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 text-xs text-gray-500\",\"children\":[[\"$\",\"span\",null,{\"children\":\"The Breakdown Editorial\"}],[\"$\",\"span\",null,{\"children\":[14,\" min\"]}],[\"$\",\"span\",null,{\"className\":\"text-amber-500/80\",\"children\":[93,\"% evidence\"]}]]}]]}]\n31:[\"$\",\"$L9\",\"rbi-repo-rate\",{\"href\":\"/story/rbi-repo-rate\",\"className\":\"group block p-6 bg-[#151515] rounded-lg border border-[#2A2A2A] hover:border-amber-500/50 transition-colors\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border bg-gray-800/50 text-gray-300 border border-gray-700 \",\"children\":[false,false,\"economy\"]}]}],[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-white group-hover:text-amber-400 transition-colors mb-2 leading-snug\",\"children\":\"RBI Repo Rate: Decoding Monetary Policy in a Changing Economy\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-400 mb-4 line-clamp-2\",\"children\":\"With the repo rate at 6.50% after 250 bps of cumulative hikes, India's monetary policy faces the challenge of balancing inflation control with growth support.\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 text-xs text-gray-500\",\"children\":[[\"$\",\"span\",null,{\"children\":\"The Breakdown Editorial\"}],[\"$\",\"span\",null,{\"children\":[10,\" min\"]}],[\"$\",\"span\",null,{\"className\":\"text-amber-500/80\",\"children\":[91,\"% evidence\"]}]]}]]}]\n32:[\"$\",\"$L9\",\"satluj-ban\",{\"href\":\"/story/satluj-ban\",\"className\":\"group block p-6 bg-[#151515] rounded-lg border border-[#2A2A2A] hover:border-amber-500/50 transition-colors\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border bg-gray-800/50 text-gray-300 border border-gray-700 \",\"children\":[false,false,\"policy\"]}]}],[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-white group-hover:text-amber-400 transition-colors mb-2 leading-snug\",\"children\":\"The Satluj Files: Censored, Released, Removed — The 48-Hour Life of India's Most Controversial Film\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-400 mb-4 line-clamp-2\",\"children\":\"Diljit Dosanjh's biopic of human rights activist Jaswant Singh Khalra survived 127 CBFC cuts, three title changes, and a pulled TIFF premiere — only to be taken down by ZEE5 within 48 hours of release. An investigation into India's censorship machinery and the story it tried to bury.\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4 text-xs text-gray-500\",\"children\":[[\"$\",\"span\",null,{\"children\":\"The Breakdown Editorial\"}],[\"$\",\"span\",null,{\"children\":[15,\" min\"]}],[\"$\",\"span\",null,{\"classNam