{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Knowledge Graph Edge Schema",
  "description": "Schema for a typed, weighted edge in The Breakdown OS Knowledge Graph",
  "type": "object",
  "required": ["id", "from", "to", "relationship", "confidence"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_|:-]+$",
      "description": "Canonical ID: <from>|<rel>|<to>"
    },
    "from": {
      "type": "string",
      "description": "Source node ID"
    },
    "to": {
      "type": "string",
      "description": "Target node ID"
    },
    "relationship": {
      "type": "string",
      "enum": [
        "implements", "created_by", "approved_by", "funded_by",
        "managed_by", "reports_to", "member_of", "located_in",
        "criticised_by", "supports", "opposes", "related_to",
        "amends", "replaces", "references", "cites",
        "depends_on", "caused_by", "influenced_by",
        "regulated_by", "audited_by"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for the relationship"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "description": "Edge weight (default 1.0, accumulates with multiple observations)"
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Source story URLs that establish this relationship"
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary metadata about the relationship"
    },
    "firstObserved": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of first observation"
    },
    "lastObserved": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of latest observation"
    },
    "active": {
      "type": "boolean",
      "description": "Whether the edge is active or soft-deleted"
    }
  }
}
