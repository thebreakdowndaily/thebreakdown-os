{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fact Memory",
  "description": "A verified fact stored for reuse across stories",
  "allOf": [
    { "$ref": "memory.schema.json" },
    {
      "type": "object",
      "required": ["statement", "verified", "confidence"],
      "properties": {
        "statement": { "type": "string", "description": "Canonical statement of the fact" },
        "verified": { "type": "boolean", "description": "Whether this fact has been verified" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Confidence in accuracy" },
        "lastVerified": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "description": "Source ID or URL" },
        "entities": { "type": "array", "items": { "type": "string" }, "description": "Related entity IDs" },
        "stories": { "type": "array", "items": { "type": "string" }, "description": "Story IDs containing this fact" },
        "category": { "type": "string", "description": "e.g., 'budget', 'statistic', 'legal', 'historical'" }
      }
    }
  ]
}
