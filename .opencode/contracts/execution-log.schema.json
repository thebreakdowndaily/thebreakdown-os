{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Execution Log",
  "description": "Schema for workflow execution logs",
  "type": "object",
  "required": ["workflow", "run_id", "version", "started_at", "steps"],
  "properties": {
    "workflow": { "type": "string" },
    "version": { "type": "string" },
    "run_id": { "type": "string", "format": "uuid" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "integer" },
    "status": { "type": "string", "enum": ["completed", "failed", "partial"] },
    "input_type": { "type": "string" },
    "input_source": { "type": "string" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "started_at"],
        "properties": {
          "id": { "type": "string" },
          "agent": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "ready", "running", "completed", "failed", "skipped", "cached"] },
          "started_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer" },
          "tokens_in": { "type": "integer" },
          "tokens_out": { "type": "integer" },
          "cache_hit": { "type": "boolean" },
          "retry_attempt": { "type": "integer" },
          "error": { "type": "string" },
          "output_summary": { "type": "string" }
        }
      }
    },
    "quality_scores": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step": { "type": "string" },
          "message": { "type": "string" },
          "retry_attempt": { "type": "integer" }
        }
      }
    }
  }
}
