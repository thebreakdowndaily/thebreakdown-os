{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "styles/**/*.ts",
    "styles/**/*.tsx",
    "lib/client/**/*.ts",
    "lib/client/**/*.tsx"
  ],
  "exclude": ["node_modules", "tests", ".next"]
}
