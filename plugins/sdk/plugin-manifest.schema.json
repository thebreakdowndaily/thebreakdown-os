{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Manifest",
  "description": "Validates every plugin's manifest.yaml file at registration time",
  "type": "object",
  "required": ["id", "name", "version", "description", "author", "type", "trust_tier", "schedule", "sources", "config"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$", "description": "Unique plugin identifier (kebab-case)" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string", "minLength": 10 },
    "author": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["data-source", "processor", "analyzer", "transformer"] },
    "trust_tier": { "type": "integer", "minimum": 1, "maximum": 5 },
    "status": { "type": "string", "enum": ["active", "inactive", "error", "deprecated"], "default": "active" },
    "schedule": { "type": "string", "description": "Cron expression or human-readable interval" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "type"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "type": { "type": "string", "enum": ["rss", "api", "scrape", "file", "websocket"] },
          "method": { "type": "string", "enum": ["GET", "POST"] },
          "auth": { "type": "string", "enum": ["none", "api-key", "oauth", "basic"] }
        }
      }
    },
    "output_schema": { "type": "string" },
    "config": { "type": "object" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "documentation": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } }
  }
}
